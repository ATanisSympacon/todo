<mvc:View
    controllerName="todo.app.controller.App" 
    id="mainAppView"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">
    <Shell>
        <App>
            <pages>
                <Page>
                    <customHeader>
                        <f:ShellBar
                            title="Meine To-Do Liste" >
                            <f:additionalContent>
                                <SearchField 
                                    width="200px" 
                                    liveChange=".onSearch" 
                                    placeholder="Suche..." />
                                
                                <MenuButton 
                                    id="filterMenuButton"
                                    text="Zustand" 
                                    type="Transparent"
                                    icon="sap-icon://order-status">
                                    <menu>
                                        <Menu>
                                            <MenuItem text="Erledigt" key="fertig" press=".onFilterStatus" />
                                            <MenuItem text="Offen" key="offen" press=".onFilterStatus" />
                                            <MenuItem text="Alle" key="alle" press=".onFilterStatus" />
                                        </Menu>
                                    </menu>
                                </MenuButton>

                                <Button
                                    icon="sap-icon://add-activity"
                                    text="Hinzufügen"
                                    type="Emphasized"
                                    press=".onAddToDo" /> 
                                <Button 
                                    text="Datum"
                                    icon="sap-icon://sort"
                                    type="Transparent"
                                    press=".onSortDate"
                                    class="sapUiTinyMarginEnd" />
                            </f:additionalContent>
                        </f:ShellBar>
                    </customHeader>
                    <content>
                        <mvc:XMLView viewName="todo.app.view.Table" />
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>